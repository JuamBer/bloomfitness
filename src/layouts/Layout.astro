---
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";

export interface Props {
  title?: string;
  description?: string;
  image?: string;
  keywords?: string;
}

import favicon from "../assets/favicon.ico";
import ogImage from "../assets/banner.webp";

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const siteTitle =
  Astro.props.title ||
  "Bloom Fitness | Entrenamiento, Fisioterapia y Nutrición Personalizada";
const siteDescription =
  Astro.props.description ||
  "Tu centro familiar de entrenamiento, fisioterapia y nutrición en Mislata. Olvídate de los gimnasios masificados. Nos centramos en tu salud, fuerza y readaptación de lesiones leves. Trato 100% personal.";
const siteKeywords =
  Astro.props.keywords ||
  "entrenamiento Mislata, fisioterapia cerca de mí, entrenador personal Mislata, gimnasio no masificado Mislata, readaptación lesiones Valencia, dolor espalda ejercicio, entrenamiento seguro, salud integral, nutrición, bloom fitness";
const socialImageURL = new URL(Astro.props.image || ogImage.src, Astro.site);
---

<!doctype html>
<html lang="es">
  <head>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-MNX52HLPYZ"
    ></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());

      gtag("config", "G-MNX52HLPYZ");
    </script>

    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/x-icon" href={favicon} />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO Meta Tags -->
    <title>{siteTitle}</title>
    <meta name="description" content={siteDescription} />
    <meta name="keywords" content={siteKeywords} />
    <meta
      name="author"
      content="Bloom Fitness - Fran Sáez, José Sáez, Gabriel Martínez, Daniel Valencia"
    />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={siteDescription} />
    <meta property="og:image" content={socialImageURL} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={siteTitle} />
    <meta property="twitter:description" content={siteDescription} />
    <meta property="twitter:image" content={socialImageURL} />

    <!-- Geo Tags for Local SEO -->
    <meta name="geo.region" content="ES-VC" />
    <meta name="geo.placename" content="Mislata, Valencia" />
    <meta name="geo.position" content="39.473568;-0.418877" />
    <meta name="ICBM" content="39.473568, -0.418877" />

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Preconnect to external origins -->
    <link rel="preconnect" href="https://use.typekit.net" crossorigin />
    <link rel="preconnect" href="https://www.google.com" />
    <link rel="dns-prefetch" href="https://maps.googleapis.com" />

    <!-- Fonts - Load asynchronously to prevent render blocking -->
    <link
      rel="stylesheet"
      href="https://use.typekit.net/zuy3mhj.css"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link rel="stylesheet" href="https://use.typekit.net/zuy3mhj.css" />
    </noscript>

    <!-- Structured Data for Local Business -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "HealthAndBeautyBusiness",
        "name": "Bloom Fitness",
        "description": "Centro de entrenamiento, fisioterapia y nutrición en Mislata, Valencia",
        "url": "https://bloomfitness.es",
        "telephone": "+34 614 047 269",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "Plaza Músico Ibars número 5",
          "addressLocality": "Mislata",
          "addressRegion": "Valencia",
          "postalCode": "46920",
          "addressCountry": "ES"
        },
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": 39.473568,
          "longitude": -0.418877
        },
        "openingHours": [
          "Mo-Fr 07:00-15:00",
          "Mo-Fr 16:00-21:00",
          "Sa 09:00-12:00",
          "Su Closed"
        ],
        "priceRange": "€€",
        "founder": [
          {
            "@type": "Person",
            "name": "Francisco Sáez García",
            "jobTitle": "Entrenador Personal"
          }
        ],
        "employee": [
          {
            "@type": "Person",
            "name": "Daniel Valencia Martín",
            "jobTitle": "Entrenador Personal"
          },
          {
            "@type": "Person",
            "name": "Gabriel Martínez Navarro",
            "jobTitle": "Entrenador Personal"
          },
          {
            "@type": "Person",
            "name": "José Sáez García",
            "jobTitle": "Fisioterapeuta"
          }
        ],
        "hasOfferCatalog": {
          "@type": "OfferCatalog",
          "name": "Servicios Bloom Fitness",
          "itemListElement": [
            {
              "@type": "Offer",
              "itemOffered": {
                "@type": "Service",
                "name": "Entrenamiento Personal",
                "description": "Entrenamiento personalizado centrado en fuerza y sistema cardiovascular"
              }
            },
            {
              "@type": "Offer",
              "itemOffered": {
                "@type": "Service",
                "name": "Fisioterapia",
                "description": "Servicios de fisioterapia especializados"
              }
            },
            {
              "@type": "Offer",
              "itemOffered": {
                "@type": "Service",
                "name": "Nutrición",
                "description": "Asesoramiento nutricional personalizado"
              }
            }
          ]
        },
        "areaServed": {
          "@type": "Place",
          "name": "Mislata y alrededores"
        }
      }
    </script>
    <ClientRouter />
  </head>

  <body>
    <slot />
  </body>
</html>
