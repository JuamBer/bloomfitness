---
import { Image } from "astro:assets";
import { products } from "../data/products";
import Button from "./Button.astro";

const showcaseImages = [
  {
    image: products[1].photos["Rojo Carmín"][2],
    title: products[1].title,
    slug: products[1].slug,
    color: "Rojo Carmín",
    class: "md:col-span-2 md:row-span-2",
    alt: "Bloom Fitness Hoodie Crimson"
  },
  {
    image: products[0].photos["Azul Turquesa"][9],
    title: products[0].title,
    slug: products[0].slug,
    color: "Azul Turquesa",
    class: "md:col-span-1 md:row-span-2",
    alt: "Bloom Fitness Hoodie Crimson"
  },
  {
    image: products[0].photos["Gris Pizarra"][5],
    title: products[0].title,
    slug: products[0].slug,
    color: "Gris Pizarra",
    class: "hidden md:block md:col-span-1 md:row-span-1",
    alt: "Your Only Limit is Mental Slate"
  },
  {
    image: products[1].photos["Gris Pizarra"][2],
    title: products[1].title,
    slug: products[1].slug,
    color: "Gris Pizarra",
    class: "md:col-span-2 md:row-span-1",
    alt: "Your Only Limit is Mental Slate"
  },
];
---

<section class="bg-black py-20 relative overflow-hidden">
  <!-- Decorative background elements -->
  <div class="absolute top-0 left-0 w-full h-full overflow-hidden pointer-events-none">
    <div class="absolute -top-[10%] -left-[10%] w-[40%] h-[40%] bg-[var(--color-orange-strong)]/5 blur-[120px] rounded-full"></div>
    <div class="absolute -bottom-[10%] -right-[10%] w-[40%] h-[40%] bg-teal-500/5 blur-[120px] rounded-full"></div>
  </div>

  <div class="max-w-7xl mx-auto px-4 relative z-10">
    <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-16">
      
      <!-- Content Area -->
      <div class="w-full lg:w-1/3 text-center lg:text-left">
        <h2 class="text-sm font-bold tracking-[0.3em] text-[var(--color-orange-strong)] uppercase mb-4">
          Lifestyle & Gear
        </h2>
        <h3 class="text-4xl md:text-5xl lg:text-6xl font-black text-white leading-tight uppercase mb-6">
          BLOOM <span class="block text-transparent bg-clip-text bg-gradient-to-r from-white to-gray-500">SHOP</span>
        </h3>
        <p class="text-gray-400 text-lg md:text-xl font-light italic mb-10 max-w-xl mx-auto lg:mx-0">
          "Más que ropa, es una declaración de intenciones. Viste la esencia de Bloom y lleva tu entrenamiento al siguiente nivel."
        </p>
        
        <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
          <Button href="/tienda" color="orange">
            Ir a la tienda 
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </Button>
        </div>
      </div>

      <!-- Bento Grid Image Gallery -->
      <div class="w-full lg:w-2/3">
        <div class="grid grid-cols-1 md:grid-cols-3 md:grid-rows-3 gap-4 lg:gap-6 h-[600px] md:h-[700px]">
          {showcaseImages.map((item, index) => (
            <a href={`/tienda/${item.slug}?color=${encodeURIComponent(item.color)}`} class={`relative group overflow-hidden rounded-2xl border border-white/10 ${item.class}`}>


              <Image 
                src={item.image} 
                alt={item.alt}
                class="w-full h-full object-cover transition-all duration-700 group-hover:scale-110 group-hover:rotate-1"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex items-end p-6">
                <div>
                  <p class="text-[var(--color-orange-strong)] font-bold text-xs uppercase tracking-widest mb-1 translate-y-4 group-hover:translate-y-0 transition-transform duration-500">
                    Bloom Collection
                  </p>
                  <p class="text-white font-bold text-xl translate-y-4 group-hover:translate-y-0 transition-transform duration-500 delay-75">
                    {item.title}
                  </p>
                </div>
              </div>
              
              <!-- Subtle glow on hover -->
              <div class="absolute inset-0 border-2 border-[var(--color-orange-strong)]/0 group-hover:border-[var(--color-orange-strong)]/50 rounded-2xl transition-all duration-500 pointer-events-none"></div>
            </a>
          ))}

        </div>
      </div>

    </div>
  </div>
</section>

<style>
  /* Custom shadow/glow for the bento cards on hover */
  .group:hover {
    box-shadow: 0 20px 50px -12px rgba(237, 109, 53, 0.2);
  }
</style>
