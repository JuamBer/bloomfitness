---
import anborBronxPdf from "../../assets/size-guides/anbor-bronx.pdf?url";
import jhkPdf from "../../assets/size-guides/jhk.pdf?url";
import ColorBar from "../../components/ColorBar.astro";
import Footer from "../../components/Footer.astro";
import Header from "../../components/Header.astro";
import { products } from "../../data/products";
import Layout from "../../layouts/Layout.astro";

type SizeGuideKey = "anbor-bronx" | "jhk";

type SizeMeasurement = {
  size: string;
  width: string;
  length: string;
};

const sizeGuides: Record<
  SizeGuideKey,
  {
    title: string;
    appliesTo: string;
    pdfUrl: string;
    measurements: SizeMeasurement[];
    notes: string[];
  }
> = {
  "anbor-bronx": {
    title: "Anbor Bronx",
    appliesTo: "Rojo Carmín y Gris Pizarra",
    pdfUrl: anborBronxPdf,
    measurements: [
      { size: "S", width: "56 cm", length: "72 cm" },
      { size: "M", width: "59 cm", length: "74 cm" },
      { size: "L", width: "62 cm", length: "76 cm" },
      { size: "XL", width: "65 cm", length: "78 cm" },
      { size: "XXL", width: "68 cm", length: "80 cm" },
    ],
    notes: [
      "Medidas aproximadas +/- 2 cm.",
      "A (Ancho): medida de sisa a sisa de la prenda plana.",
      "B (Largo): medida desde el hombro hasta el inferior de la prenda.",
    ],
  },
  jhk: {
    title: "JHK",
    appliesTo: "Azul Turquesa",
    pdfUrl: jhkPdf,
    measurements: [
      { size: "XS", width: "52 cm", length: "70 cm" },
      { size: "S", width: "55 cm", length: "72 cm" },
      { size: "M", width: "57 cm", length: "75 cm" },
      { size: "L", width: "60 cm", length: "77 cm" },
      { size: "XL", width: "63 cm", length: "79 cm" },
      { size: "XXL", width: "67 cm", length: "81 cm" },
    ],
    notes: ["Medidas en centímetros según la guía técnica JHK."],
  },
};

const allGuides = Object.entries(sizeGuides).map(([key, guide]) => ({
  key: key as SizeGuideKey,
  ...guide,
}));

const contextText =
  "Selecciona una camiseta desde la tienda para ver automáticamente su guía de tallas correcta.";
---

<Layout
  title="Guía de Tallas | Bloom Fitness Shop"
  description="Consulta la guía de tallas correcta según producto y color. Incluye las fichas técnicas Anbor y JHK en PDF."
  keywords="guía de tallas, medidas camisetas, tallaje ropa, bloom fitness shop"
>
  <Header />

  <main class="min-h-screen bg-black pt-12 pb-20 px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl mx-auto">
      <nav class="flex mb-8" aria-label="Breadcrumb">
        <ol
          class="flex items-center space-x-2 text-xs uppercase tracking-widest text-gray-500"
        >
          <li>
            <a
              href="/tienda"
              class="hover:text-[var(--color-orange-strong)] transition-colors"
              >Tienda</a
            >
          </li>
          <li><span class="mx-2">/</span></li>
          <li class="text-[var(--color-orange-strong)] font-bold">
            Guía de Tallas
          </li>
        </ol>
      </nav>

      <h1
        class="text-4xl md:text-5xl font-extrabold tracking-tight text-white uppercase mb-8"
      >
        Guía de <span class="text-[var(--color-orange-strong)]">Tallas</span>
      </h1>

      <div class="prose prose-invert max-w-none mb-12">
        <p class="text-gray-300 text-lg leading-relaxed">
          El tallaje de nuestras camisetas depende del modelo base. Usamos guía
          <strong class="text-white">Anbor Bronx</strong> para colores
          <strong class="text-white"> Rojo Carmín y Gris Pizarra</strong>, y
          guía <strong class="text-white">JHK</strong> para
          <strong class="text-white"> Azul Turquesa</strong>.
        </p>
        <p class="text-sm text-[var(--color-orange-strong)] font-semibold mt-4">
          <span id="size-guide-context-text">{contextText}</span>
        </p>
      </div>

      <div class="space-y-8">
        {
          allGuides.map((guide) => (
            <section
              class="bg-zinc-900 border border-zinc-800 rounded-xl p-4 sm:p-6 shadow-2xl"
              id={`size-guide-${guide.key}`}
              data-guide-key={guide.key}
            >
              <h2 class="text-xl font-bold text-white uppercase tracking-wide">
                {guide.title}
              </h2>
              <p class="text-xs uppercase tracking-wider text-gray-400 mt-2">
                Aplica a:
              </p>
              <p class="text-xs uppercase tracking-wider text-[var(--color-orange-strong)] font-semibold mt-1">
                {guide.appliesTo}
              </p>

              <div class="mt-5 overflow-x-auto border border-zinc-800 rounded-lg">
                <table class="w-full text-left text-sm text-gray-200 border-collapse">
                  <thead>
                    <tr class="bg-zinc-800/70 border-b border-zinc-700">
                      <th class="px-4 py-3 font-bold uppercase tracking-wider text-xs">
                        Talla
                      </th>
                      <th class="px-4 py-3 font-bold uppercase tracking-wider text-xs">
                        A (Ancho)
                      </th>
                      <th class="px-4 py-3 font-bold uppercase tracking-wider text-xs">
                        B (Largo)
                      </th>
                    </tr>
                  </thead>
                  <tbody class="divide-y divide-zinc-800 bg-zinc-900/80">
                    {guide.measurements.map((measurement) => (
                      <tr class="hover:bg-zinc-800/40 transition-colors">
                        <td class="px-4 py-3 font-bold text-[var(--color-orange-strong)]">
                          {measurement.size}
                        </td>
                        <td class="px-4 py-3">{measurement.width}</td>
                        <td class="px-4 py-3">{measurement.length}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>

              <ul class="mt-3 space-y-1 text-xs text-gray-400">
                {guide.notes.map((note) => (
                  <li>{note}</li>
                ))}
              </ul>

              <div class="mt-4 flex flex-wrap gap-3">
                <a
                  href={guide.pdfUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center justify-center px-4 py-2 text-xs font-bold uppercase tracking-wider bg-zinc-800 border border-zinc-700 text-white rounded-md hover:border-[var(--color-orange-strong)] hover:text-[var(--color-orange-strong)] transition-colors"
                >
                  Abrir PDF
                </a>
                <a
                  href={guide.pdfUrl}
                  download
                  class="inline-flex items-center justify-center px-4 py-2 text-xs font-bold uppercase tracking-wider bg-transparent border border-zinc-700 text-gray-300 rounded-md hover:border-[var(--color-orange-strong)] hover:text-[var(--color-orange-strong)] transition-colors"
                >
                  Descargar PDF
                </a>
              </div>
            </section>
          ))
        }
      </div>

      <div class="mt-16 text-center">
        <a
          href="/tienda"
          class="inline-flex items-center gap-2 text-white font-bold uppercase tracking-widest hover:text-[var(--color-orange-strong)] transition-colors group"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="transition-transform group-hover:-translate-x-1"
            ><path d="m15 18-6-6 6-6"></path></svg
          >
          Volver a la Tienda
        </a>
      </div>
    </div>
  </main>

  <ColorBar loading="lazy" />
  <Footer />
</Layout>

<script define:vars={{ products }}>
  window.sizeGuideProducts = products;
</script>

<script is:inline>
  function showAllGuides() {
    const sections = document.querySelectorAll("[data-guide-key]");
    sections.forEach((section) => section.classList.remove("hidden"));
  }

  function showSingleGuide(guideKey) {
    const sections = document.querySelectorAll("[data-guide-key]");
    sections.forEach((section) => {
      if (section.getAttribute("data-guide-key") === guideKey) {
        section.classList.remove("hidden");
      } else {
        section.classList.add("hidden");
      }
    });
  }

  function setContextText(text) {
    const contextEl = document.getElementById("size-guide-context-text");
    if (contextEl) contextEl.textContent = text;
  }

  function resolveGuideFromParams() {
    const urlParams = new URLSearchParams(window.location.search);
    const slugParam = (urlParams.get("slug") || "").trim();
    const colorParam = (urlParams.get("color") || "").trim();

    if (!slugParam) {
      showAllGuides();
      setContextText(
        "No se recibió producto. Mostramos ambas guías para que puedas comprobar el tallaje.",
      );
      return;
    }

    const selectedProduct = (window.sizeGuideProducts || []).find(
      (product) => product.slug === slugParam,
    );

    if (!selectedProduct) {
      showAllGuides();
      setContextText(
        "Producto no reconocido. Mostramos ambas guías para que puedas comprobar el tallaje.",
      );
      return;
    }

    const hasValidColor = colorParam
      ? selectedProduct.colors.includes(colorParam)
      : false;
    const resolvedColor = hasValidColor
      ? colorParam
      : selectedProduct.colors[0];
    const resolvedGuideKey = selectedProduct.sizeGuideByColor?.[resolvedColor];

    if (!resolvedGuideKey) {
      showAllGuides();
      setContextText(
        `No se pudo resolver una guía concreta para ${selectedProduct.title}. Mostramos ambas guías.`,
      );
      return;
    }

    showSingleGuide(resolvedGuideKey);
    setContextText(
      `Mostrando guía para ${selectedProduct.title}${resolvedColor ? ` en ${resolvedColor}` : ""}.`,
    );
  }

  document.addEventListener("astro:page-load", resolveGuideFromParams);
</script>
