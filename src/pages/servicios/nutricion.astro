---
import { Image } from "astro:assets";
import apple from "../../assets/icons/apple-whole-solid-full.svg";
import calculator from "../../assets/icons/calculator-solid-full.svg";
import calendarCheck from "../../assets/icons/calendar-check-solid-full.svg";
import percent from "../../assets/icons/percent-solid-full.svg";
import puzzle from "../../assets/icons/puzzle-piece-solid-full.svg";
import question from "../../assets/icons/question-solid-full.svg";
import ColorBar from "../../components/ColorBar.astro";
import Footer from "../../components/Footer.astro";
import Header from "../../components/Header.astro";
import ProfessionalsSidebar from "../../components/ProfessionalsSidebar.astro";
import { ProfessionalArea, professionals } from "../../data/professionals";
import Layout from "../../layouts/Layout.astro";

const nutritionists = professionals.filter(
  (p) => p.area === ProfessionalArea.NUTRICIONISTA,
);
const nutritionServiceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: "Nutricionista y nutricion en Mislata",
  serviceType: "Nutricion",
  areaServed: {
    "@type": "City",
    name: "Mislata",
  },
  provider: {
    "@type": "HealthAndBeautyBusiness",
    name: "Bloom Fitness",
    url: "https://bloomfitness.es",
    telephone: "+34 614 047 269",
    address: {
      "@type": "PostalAddress",
      streetAddress: "Plaza Musico Ibars numero 5",
      addressLocality: "Mislata",
      addressRegion: "Valencia",
      postalCode: "46920",
      addressCountry: "ES",
    },
  },
  offers: {
    "@type": "Offer",
    priceCurrency: "EUR",
    price: "45",
    description: "Revisiones de nutricion desde 45 EUR",
  },
  url: "https://bloomfitness.es/servicios/nutricion",
};

const nutritionFaqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "Cuanto cuesta el servicio de nutricionista en Mislata?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "La sesion inicial son 65 euros e incluye valoracion y plan personalizado. Las revisiones son de 45 euros.",
      },
    },
    {
      "@type": "Question",
      name: "Sirve para perder grasa o mejorar rendimiento?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Si. Adaptamos la estrategia segun tu objetivo: salud, composicion corporal, rendimiento o adherencia a largo plazo.",
      },
    },
  ],
};
---

<Layout
  title="Nutricionista y Nutricion en Mislata | Bloom Fitness"
  description="Servicio de nutricionista en Mislata con evaluacion, plan nutricional personalizado y revisiones para salud, composicion corporal y rendimiento."
  keywords="nutricionista Mislata, nutricion Mislata, dieta personalizada Mislata, nutricion deportiva Mislata, perdida de peso Mislata, Bloom Fitness"
>
  <script type="application/ld+json" set:html={JSON.stringify(nutritionServiceSchema)}></script>
  <script type="application/ld+json" set:html={JSON.stringify(nutritionFaqSchema)}></script>
  <Header />
  <ColorBar />

  <main class="min-h-screen bg-black pt-16 pb-16">
    <nav class="max-w-7xl mx-auto px-6 md:px-12 mb-8" aria-label="Migas de pan">
      <ol class="flex items-center gap-2 text-sm">
        <li>
          <a
            href="/servicios"
            class="text-gray-400 hover:text-[var(--color-orange-light)] transition-colors"
          >
            Servicios
          </a>
        </li>
        <li class="text-gray-600">/</li>
        <li class="text-[var(--color-orange-light)] font-semibold">
          Nutrición
        </li>
      </ol>
    </nav>

    <section class="max-w-7xl mx-auto px-6 md:px-12 mb-16">
      <span
        class="text-[var(--color-orange-light)] uppercase tracking-wider font-bold text-sm mb-2 block"
        transition:name="servicio-numero-03">03</span
      >
      <h1
        class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-extrabold tracking-wider text-white uppercase mb-8"
        transition:name="servicio-nombre-nutricion"
      >
        NUTRICIÓN <span class="text-[var(--color-orange-light)]"
          >EN MISLATA</span
        >
      </h1>
      <p class="text-gray-300 text-lg md:text-xl max-w-3xl leading-relaxed">
        Asesoramiento nutricional personalizado en Mislata para complementar tu
        entrenamiento y optimizar tus resultados. Planes adaptados a tus
        objetivos y estilo de vida.
      </p>
      <p class="text-gray-400 text-base md:text-lg max-w-3xl leading-relaxed mt-4">
        Si buscas nutricionista en Mislata, te acompaniamos con pautas practicas,
        revisiones y educacion nutricional para resultados sostenibles.
      </p>
    </section>

    <div
      class="max-w-7xl mx-auto px-6 md:px-12 mb-16 grid md:grid-cols-12 gap-8 lg:gap-12"
    >
      <div class="md:col-span-4 lg:col-span-3 order-last md:order-first">
        <ProfessionalsSidebar
          professionals={nutritionists}
          title="Nuestro Nutricionista"
          color="text-[var(--color-orange-light)]"
        />
      </div>
      <div class="md:col-span-8 lg:col-span-9 space-y-16">
        <section>
          <h2
            class="text-white font-bold text-2xl uppercase tracking-wide mb-6 flex items-center gap-3"
          >
            <span
              class="w-8 h-[2px] bg-[var(--color-orange-light)] inline-block"
            ></span>
            Nuestros Servicios
          </h2>
          <div class="grid md:grid-cols-2 gap-6 max-w-2xl">
            <div
              class="bg-gradient-to-br from-gray-900 to-gray-800 border-2 border-[var(--color-orange-light)] rounded-xl p-8"
            >
              <h3
                class="text-white font-bold text-xl uppercase tracking-wide mb-2"
              >
                Sesión Inicial
              </h3>
              <p class="text-gray-400 text-sm mb-4">
                Evaluación completa, historial, objetivos y plan nutricional
                personalizado.
              </p>
              <p
                class="text-[var(--color-orange-light)] text-4xl font-extrabold"
              >
                65€
              </p>
            </div>
            <div
              class="bg-gray-900 border border-gray-700 rounded-lg p-8 hover:border-[var(--color-orange-light)] transition-all duration-300"
            >
              <h3
                class="text-white font-bold text-xl uppercase tracking-wide mb-2"
              >
                Revisión
              </h3>
              <p class="text-gray-400 text-sm mb-4">
                Seguimiento, ajustes del plan y resolución de dudas.
              </p>
              <p class="text-white text-4xl font-extrabold">45€</p>
            </div>
          </div>
        </section>
        <section>
          <h2
            class="text-white font-bold text-2xl uppercase tracking-wide mb-6 flex items-center gap-3"
          >
            <span
              class="w-8 h-[2px] bg-[var(--color-orange-light)] inline-block"
            ></span>
            Preguntas frecuentes
          </h2>
          <div class="space-y-4">
            <article class="bg-gray-900 border border-gray-700 rounded-lg p-5">
              <h3 class="text-white font-bold mb-2">
                Cuanto cuesta el servicio de nutricionista en Mislata?
              </h3>
              <p class="text-gray-300 text-sm">
                La sesion inicial son 65 euros e incluye valoracion y plan
                personalizado. Las revisiones son de 45 euros.
              </p>
            </article>
            <article class="bg-gray-900 border border-gray-700 rounded-lg p-5">
              <h3 class="text-white font-bold mb-2">
                Sirve para perder grasa o mejorar rendimiento?
              </h3>
              <p class="text-gray-300 text-sm">
                Si. Adaptamos la estrategia segun tu objetivo: salud, composicion
                corporal, rendimiento o adherencia a largo plazo.
              </p>
            </article>
          </div>
        </section>

        <section>
          <h2
            class="text-white font-bold text-2xl uppercase tracking-wide mb-6 flex items-center gap-3"
          >
            <span
              class="w-8 h-[2px] bg-[var(--color-orange-light)] inline-block"
            ></span>
            ¿Qué Incluye?
          </h2>
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
            <div class="bg-gray-900 border border-gray-700 rounded-lg p-6">
              <div class="mb-4">
                <Image
                  src={calculator}
                  alt="Evaluación Inicial"
                  class="w-8 h-8 text-[var(--color-orange-light)] invert"
                  loading="lazy"
                />
              </div>
              <h3 class="text-white font-bold text-lg mb-2">
                Evaluación Inicial
              </h3>
              <p class="text-gray-400 text-sm">
                Análisis completo de tu historial alimentario, hábitos y
                objetivos personales.
              </p>
            </div>
            <div class="bg-gray-900 border border-gray-700 rounded-lg p-6">
              <div class="mb-4">
                <Image
                  src={apple}
                  alt="Plan Personalizado"
                  class="w-8 h-8 text-[var(--color-orange-light)] invert"
                  loading="lazy"
                />
              </div>
              <h3 class="text-white font-bold text-lg mb-2">
                Plan Personalizado
              </h3>
              <p class="text-gray-400 text-sm">
                Dieta adaptada a tus necesidades, preferencias y estilo de vida.
              </p>
            </div>
            <div class="bg-gray-900 border border-gray-700 rounded-lg p-6">
              <div class="mb-4">
                <Image
                  src={percent}
                  alt="Seguimiento"
                  class="w-8 h-8 text-[var(--color-orange-light)] invert"
                  loading="lazy"
                />
              </div>
              <h3 class="text-white font-bold text-lg mb-2">Seguimiento</h3>
              <p class="text-gray-400 text-sm">
                Ajustes continuos basados en tu progreso y evolución.
              </p>
            </div>
            <div class="bg-gray-900 border border-gray-700 rounded-lg p-6">
              <div class="mb-4">
                <Image
                  src={calendarCheck}
                  alt="Objetivos Claros"
                  class="w-8 h-8 text-[var(--color-orange-light)] invert"
                  loading="lazy"
                />
              </div>
              <h3 class="text-white font-bold text-lg mb-2">
                Objetivos Claros
              </h3>
              <p class="text-gray-400 text-sm">
                Metas realistas y alcanzables definidas conjuntamente.
              </p>
            </div>
            <div class="bg-gray-900 border border-gray-700 rounded-lg p-6">
              <div class="mb-4">
                <Image
                  src={puzzle}
                  alt="Integración"
                  class="w-8 h-8 text-[var(--color-orange-light)] invert"
                  loading="lazy"
                />
              </div>
              <h3 class="text-white font-bold text-lg mb-2">Integración</h3>
              <p class="text-gray-400 text-sm">
                Coordinación con tu programa de entrenamiento para máximos
                resultados.
              </p>
            </div>
            <div class="bg-gray-900 border border-gray-700 rounded-lg p-6">
              <div class="mb-4">
                <Image
                  src={question}
                  alt="Soporte"
                  class="w-8 h-8 text-[var(--color-orange-light)] invert"
                  loading="lazy"
                />
              </div>
              <h3 class="text-white font-bold text-lg mb-2">Soporte</h3>
              <p class="text-gray-400 text-sm">
                Resolución de dudas y apoyo durante todo el proceso.
              </p>
            </div>
          </div>
        </section>
      </div>
    </div>
    <section class="py-16">
      <div class="max-w-7xl mx-auto px-6 md:px-12 text-center">
        <h2
          class="text-2xl sm:text-3xl md:text-4xl font-extrabold tracking-wider text-white uppercase mb-6"
        >
          ¿Quieres mejorar tu alimentación?
        </h2>
        <p class="text-gray-300 text-lg mb-8 max-w-2xl mx-auto">
          Contacta con nosotros para más información o reserva tu consulta
          directamente.
        </p>
        <a
          href="https://reserve.timp.pro/centers/18931-bloom-fitness-mislata/connect_activities/5345"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Reservar consulta de nutricion en Mislata"
          class="inline-block px-8 py-4 text-white font-bold text-lg uppercase tracking-wide rounded-full transition-all duration-300 shadow-lg hover:shadow-2xl relative overflow-hidden cursor-pointer group"
        >
          <span class="relative z-10">RESERVAR</span>
          <div
            class="absolute inset-0 bg-gradient-to-r from-[var(--color-orange-light)] via-[var(--color-orange-strong)] to-[var(--color-orange-light)] bg-[length:200%_100%] group-hover:animate-[gradient-shift_2s_ease_infinite]"
          >
          </div>
        </a>
      </div>
    </section>
  </main><ColorBar />
  <Footer /></Layout
>

<style>
  @keyframes gradient-shift {
    0% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
    100% {
      background-position: 0% 50%;
    }
  }
</style>
