---
import ColorBar from "../components/ColorBar.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import Layout from "../layouts/Layout.astro";
import Button from "../components/Button.astro";
import ServiceCard from "../components/ServiceCard.astro";
import DiscountCard from "../components/DiscountCard.astro";
---

<Layout
  title="Servicios de Entrenamiento, Fisioterapia y Nutricion en Mislata | Bloom Fitness"
  description="Servicios en Mislata de entrenamiento personal y grupal, fisioterapia y nutricion. Conoce precios, bonos y programas personalizados en Bloom Fitness."
  keywords="servicios Mislata, entrenamiento personal Mislata, entrenamiento grupal Mislata, fisioterapia Mislata, nutricionista Mislata, nutricion Mislata, Bloom Fitness"
>
  <Header />
  <ColorBar />

  <main class="min-h-screen bg-black pt-16 pb-16">
    <section
      class="max-w-7xl mx-auto px-6 md:px-12 mb-20"
      aria-labelledby="servicios-intro-title"
    >
      <h1
        id="servicios-intro-title"
        class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-extrabold tracking-wider text-white uppercase mb-8"
      >
        SERVICIOS <span class="text-[var(--color-orange-strong)]"
          >EN MISLATA</span
        >
      </h1>
      <p class="text-gray-300 text-lg md:text-xl max-w-3xl leading-relaxed">
        En Bloom Fitness ofrecemos servicios personalizados de entrenamiento,
        fisioterapia y nutrición en Mislata para ayudarte a alcanzar tus
        objetivos de salud y bienestar. Descubre nuestras tarifas y encuentra el
        plan perfecto para ti.
      </p>
    </section>

    <section
      class="max-w-7xl mx-auto px-6 md:px-12 mb-20"
      aria-label="Listado de servicios en Mislata"
    >
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <ServiceCard
          href="/servicios/entrenamiento"
          number="01"
          title="ENTRENAMIENTO"
          description="Programas de entrenamiento individual y grupal con valoración funcional completa."
          tags={["Individual", "Grupal", "VAF"]}
          price="Desde 50€/mes"
          colorVar="--color-orange-strong"
        />

        <ServiceCard
          href="/servicios/fisioterapia"
          number="02"
          title="FISIOTERAPIA"
          description="Tratamiento, recuperación y prevención de lesiones con seguimiento personalizado."
          tags={["Sesiones", "Bonos", "Programas"]}
          price="Desde 25€/sesión"
          colorVar="--color-blue"
        />

        <ServiceCard
          href="/servicios/nutricion"
          number="03"
          title="NUTRICIÓN"
          description="Asesoramiento nutricional personalizado para optimizar tus resultados."
          tags={["Evaluación", "Plan personalizado"]}
          price="Desde 45€/sesión"
          colorVar="--color-orange-light"
        />
      </div>
    </section>

    <section class="max-w-7xl mx-auto px-6 md:px-12 mb-20">
      <DiscountCard
        href="/servicios/descuentos"
        description="Descubre cómo ahorrar en tus cuotas mediante nuestro sistema de referidos y beneficios especiales por edad o discapacidad."
        discount="Hasta 10%"
        label="Acumulable"
      />
    </section>

    <section class="py-16">
      <div class="max-w-7xl mx-auto px-6 md:px-12 text-center">
        <h2
          class="text-2xl sm:text-3xl md:text-4xl font-extrabold tracking-wider text-white uppercase mb-6"
        >
          ¿Listo para empezar?
        </h2>
        <p class="text-gray-300 text-lg mb-8 max-w-2xl mx-auto">
          Contacta con nosotros para más información o para reservar tu primera
          sesión. Estamos aquí para ayudarte a alcanzar tus objetivos.
        </p>
        <Button href="/contacto" color="red" size="lg">
          Contactar
        </Button>
      </div>
    </section>
  </main>

  <ColorBar />
  <Footer />
</Layout>


